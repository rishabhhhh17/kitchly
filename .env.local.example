# Admin dashboard
ADMIN_PASSWORD=change-me-to-something-strong
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-32-plus-character-random-string

# Public site URL (used by Pixel + canonical)
NEXT_PUBLIC_SITE_URL=https://kitchly.co.in
